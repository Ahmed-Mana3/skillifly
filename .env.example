# ============================================================
#  Skillifly — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git — it is listed in .gitignore.
# ============================================================

# ------------------------------------------------------------------
# Django Core  (REQUIRED in production)
# ------------------------------------------------------------------

# A long, random, unique string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key

# Set to False in production — True only for local development.
DJANGO_DEBUG=True

# Comma-separated list of your domain(s) and/or VPS IP.
# Example: skillifly.cloud,www.skillifly.cloud,123.45.67.89
DJANGO_ALLOWED_HOSTS=skillifly.cloud,www.skillifly.cloud
DEFAULT_FROM_EMAIL='Skillifly <noreply@skillifly.cloud>'

# The Django Site ID (usually 1 unless you run multiple sites).
DJANGO_SITE_ID=1

# Comma-separated trusted origins for CSRF protection (required behind Nginx).
# Must include the full scheme (https://).
DJANGO_CSRF_TRUSTED_ORIGINS=https://skillifly.cloud,https://www.skillifly.cloud

# Django log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
DJANGO_LOG_LEVEL=INFO

# ------------------------------------------------------------------
# Database (SQLite)
# ------------------------------------------------------------------
#
# SQLite is used by default. Leave DATABASE_URL empty.
# Make sure the db.sqlite3 file is writable by the web server user (www-data).
#
DATABASE_URL=

# FUTURE PostgreSQL migration (uncomment and fill when ready):
#   Also add psycopg2-binary to requirements.txt at that point.
#
# DATABASE_URL=postgres://skillifly_user:strongpassword@localhost:5432/skillifly_db
# DB_CONN_MAX_AGE=60

# ------------------------------------------------------------------
# Google OAuth2  (leave empty to disable Google login)
# ------------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------
# Kashier Payment Gateway  (REQUIRED for payment features)
# ------------------------------------------------------------------

KASHIER_MERCHANT_ID=MID-43351-304
KASHIER_API_KEY=15eba873-8d1f-4b2d-84fb-c27bd2f40ce1
KASHIER_WEBHOOK_SECRET=760e1d629d0c1f54f81c8011db251df7$2c6cae8110f74866251c9185c23c5cc395e5922d70c489de41560ecdba558a9932a2620e3b2f435b909673a566d059cb
KASHIER_MODE=test

# Optional coupon code to bypass payment (e.g. for internal testing).
# Leave empty to disable.
SKILLIFLY_COUPON_CODE=SKILLIFLY2026

# ------------------------------------------------------------------
# Celery / Redis  (REQUIRED for async PDF export)
# ------------------------------------------------------------------

# Redis connection URL
CELERY_BROKER_URL=redis://localhost:6379/0

# Set to False in production so tasks run in a real Celery worker.
# Set to True only in development to run tasks synchronously.
CELERY_TASK_ALWAYS_EAGER=False

# ------------------------------------------------------------------
# HTTPS / HSTS  (only enable AFTER HTTPS is fully configured)
# ------------------------------------------------------------------

# Set to True ONLY after Let's Encrypt cert is installed and working.
DJANGO_SECURE_HSTS=False
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True


